# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# AI tools
.aider*

# Build artifacts. Anchored to the repo root with a leading slash: `go build`
# and dev-install.sh only ever drop a binary here, while "agent-factory" and
# "af" are legitimate DIRECTORY names deeper in the tree — the af skill and the
# generated agent plugins are named after the tool (plugins/*/agent-factory/,
# session/agentskill.go:19). An unanchored pattern matches at any depth and
# silently swallowed them.
/agent-factory
/af
/cs
*.exe
*.dll
*.so
*.dylib

# OS
.DS_Store
Thumbs.db

# Test
*.test
# *.test is for compiled Go test binaries — keep the container image recipe
!Dockerfile.test
*.out
coverage.txt

# Go
vendor/

# Debug
*.prof
__debug_bin*

# Web client toolchain (#1592 Phase 5). node_modules is never committed; the built
# web/dist/ IS committed (locked decision) so `go build`/Go tests stay Node-free.
web/node_modules/
web/*.tsbuildinfo
# Playwright web-driver-selftest run artifacts (#1592 Phase 5 PR6). The harness
# sources (web/playwright.config.ts, web/selftest/*.spec.ts) ARE committed; only
# the per-run outputs below are ignored.
web/test-results/
web/playwright-report/
web/.playwright/
web/selftest/.last-run.json
web/blob-report/

# MkDocs build output
site/

# Local docs virtualenv (see requirements-docs.txt)
.venv-docs/
